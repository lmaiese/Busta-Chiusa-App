rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isBanditore(sid) {
      return isAuth() &&
        get(/databases/$(database)/documents/sessions/$(sid)).data.banditorId == request.auth.uid;
    }

    function isParticipant(sid) {
      return isAuth() &&
        exists(/databases/$(database)/documents/sessions/$(sid)/participants/$(request.auth.uid));
    }

    function isSessionMember(sid) {
      return isBanditore(sid) || isParticipant(sid);
    }

    // Sessions
    match /sessions/{sid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.banditorId == request.auth.uid;
      allow update, delete: if isBanditore(sid);

      // Participants
      match /participants/{uid} {
        allow list: if isAuth();
        allow get: if isSessionMember(sid);
        allow create: if isAuth() && request.auth.uid == uid;
        allow update: if isAuth() && (request.auth.uid == uid || isBanditore(sid));
        allow delete: if isBanditore(sid);

        // Roster
        match /roster/{playerId} {
          allow read: if isSessionMember(sid);
          allow write: if false;
        }
      }

      // Players (listone)
      match /players/{playerId} {
        allow read: if isAuth();
        allow create: if isBanditore(sid);
        allow update, delete: if false;
      }

      // Current Auction
      match /currentAuction/state {
        allow read: if isAuth();
        allow create: if isBanditore(sid);
        allow update: if isBanditore(sid) || (
          isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bidCount']) &&
          request.resource.data.bidCount is int &&
          request.resource.data.bidCount == resource.data.bidCount + 1
        );
        allow delete: if false;

        // Bids: secret — Cloud Functions read via Admin SDK
        match /bids/{uid} {
          allow create, update: if isAuth() &&
            request.auth.uid == uid &&
            request.resource.data.keys().hasAll(['amount', 'submittedAt', 'round']) &&
            request.resource.data.amount is int &&
            request.resource.data.amount >= 1;
          allow read: if false;
          allow delete: if isAuth() && request.auth.uid == uid;
        }

        // Passes: public within session — anyone can see who passed
        match /passes/{uid} {
          allow read: if isAuth();
          allow create, update: if isAuth() && request.auth.uid == uid;
          allow delete: if isAuth() && request.auth.uid == uid;
        }
      }

      // Auction History
      match /auctionHistory/{histId} {
        allow read: if isSessionMember(sid);
        allow write: if false;
      }
    }
  }
}
